{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Play PixelTone Linux",
            "type": "shell",
            "command": "./.venv/bin/python",
            "args": [
                "src/main.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}